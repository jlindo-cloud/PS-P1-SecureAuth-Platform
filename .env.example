# Clave secreta de Flask (sesiones, CSRF). Generar una propia en producción:
# python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=change_me_secret

# "production" activa redirección forzada a HTTPS y desactiva el aviso de
# codigo OTP en pantalla (en dev se muestra el codigo por conveniencia).
FLASK_ENV=development
