# =========================================================
# SecureAuth Store — plantilla de variables de entorno
#
# 1. Copiar este archivo a .env
# 2. Reemplazar cada valor de ejemplo por uno propio
# 3. NUNCA subir el archivo .env al repositorio
# =========================================================

# ---------------------------------------------------------
# ENTORNO
# ---------------------------------------------------------
APP_ENV=development
FLASK_DEBUG=1
SESSION_MINUTES=30

# ---------------------------------------------------------
# SECRETOS DE LA APLICACIÓN
# Generar cada uno con:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
# ---------------------------------------------------------
FLASK_SECRET_KEY=GENERAR_VALOR_ALEATORIO_LARGO
AUDIT_HMAC_KEY=GENERAR_OTRO_VALOR_ALEATORIO_LARGO

# Pepper de contraseñas (Nivel 2). Secreto global del servidor
# que se combina con cada contraseña antes del hash Argon2id.
# En producción es OBLIGATORIO y debe vivir en Key Vault.
PASSWORD_PEPPER=GENERAR_UN_TERCER_VALOR_ALEATORIO_LARGO

# ---------------------------------------------------------
# MFA POR CÓDIGO OTP (Nivel 4)
# ---------------------------------------------------------
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
PASSWORD_MIN_LENGTH=12

# ---------------------------------------------------------
# CORREO SALIENTE — canal del segundo factor
#
# Con Gmail se requiere una CONTRASEÑA DE APLICACIÓN:
#   1. Activar la verificación en 2 pasos de la cuenta
#      (myaccount.google.com > Seguridad).
#   2. Seguridad > Contraseñas de aplicaciones > generar una.
#   3. Pegar aquí ese valor de 16 caracteres, NUNCA la
#      contraseña personal de la cuenta.
#
# Sin SMTP configurado la app funciona en modo desarrollo y
# escribe el código en el log. En producción es obligatorio.
# ---------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_SSL=0
SMTP_USER=tu-correo@gmail.com
SMTP_PASSWORD=CONTRASENA_DE_APLICACION_16_CARACTERES
MAIL_FROM=SecureAuth Store <tu-correo@gmail.com>

# ---------------------------------------------------------
# AUTENTICACIÓN — GOOGLE OAUTH (opcional)
#
# El login local con contraseña + OTP funciona sin esto.
# Para habilitar "Continuar con Google", obtener credenciales
# en Google Cloud Console > APIs y servicios > Credenciales.
# URI de redireccionamiento: http://localhost:5000/auth/google/callback
# ---------------------------------------------------------
GOOGLE_CLIENT_ID=000000000000-xxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=NO_SUBIR_A_GIT
GOOGLE_REDIRECT_URI=http://localhost:5000/auth/google/callback

# Primer usuario que recibirá el rol Admin al registrarse
BOOTSTRAP_ADMIN_EMAIL=tu-correo@ejemplo.com

# ---------------------------------------------------------
# ADMINISTRADOR INICIAL (solo producción)
#
# En local, seed.py crea admin@example.com y
# cliente@example.com con contraseñas conocidas.
#
# En producción (APP_ENV=production) esas cuentas NO se
# crean: sus direcciones no existen y nunca recibirían el
# código de verificación. En su lugar seed.py crea este
# administrador, que debe usar un correo REAL.
# ---------------------------------------------------------
ADMIN_EMAIL=tu-correo-real@gmail.com
ADMIN_PASSWORD=UnaContrasenaPropia#2026
ADMIN_NAME=Administrador

# Permite OAuth sobre HTTP. SOLO desarrollo local.
AUTHLIB_INSECURE_TRANSPORT=true

# ---------------------------------------------------------
# BASE DE DATOS
# ---------------------------------------------------------
DATABASE_URL=sqlite:///secureauth.db

# Producción: Azure SQL con identidad administrada.
# DATABASE_URL=mssql+pyodbc://@TU-SERVIDOR.database.windows.net/secureauth?driver=ODBC+Driver+18+for+SQL+Server&authentication=ActiveDirectoryMsi&Encrypt=yes&TrustServerCertificate=no

# ---------------------------------------------------------
# ALMACENAMIENTO DE IMÁGENES — AZURE BLOB (opcional en local)
# ---------------------------------------------------------
AZURE_STORAGE_ACCOUNT_URL=https://TUCUENTA.blob.core.windows.net
AZURE_STORAGE_CONTAINER=product-images

# ---------------------------------------------------------
# LÍMITES Y CSRF
# ---------------------------------------------------------
MAX_CONTENT_LENGTH=3145728
MAX_IMAGE_BYTES=2097152
WTF_CSRF_TIME_LIMIT=3600

# Producción multi-instancia: Redis para rate limiting
# RATELIMIT_STORAGE_URI=redis://:PASSWORD@HOST:6380/0?ssl=true
